{
  "name": "@magmacomputing/tempo",
  "version": "2.2.0",
  "description": "The Tempo core library",
  "author": "Magma Computing Solutions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magmacomputing/magma.git",
    "directory": "packages/tempo"
  },
  "homepage": "https://github.com/magmacomputing/magma/tree/main/packages/tempo#readme",
  "bugs": {
    "url": "https://github.com/magmacomputing/magma/issues"
  },
  "keywords": [
    "temporal",
    "date",
    "time",
    "immutable",
    "fluent",
    "parsing"
  ],
  "type": "module",
  "main": "dist/tempo.index.js",
  "types": "dist/tempo.index.d.ts",
  "imports": {
    "#library": "@magmacomputing/library",
    "#library/*.js": "@magmacomputing/library/common/*.js",
    "#tempo": {
      "development": "./src/tempo.index.ts",
      "default": "./dist/tempo.index.js"
    },
    "#tempo/core": {
      "development": "./src/core.index.ts",
      "default": "./dist/core.index.js"
    },
    "#tempo/duration": {
      "development": "./src/plugin/module/module.duration.ts",
      "default": "./dist/plugin/module/module.duration.js"
    },
    "#tempo/format": {
      "development": "./src/plugin/module/module.format.ts",
      "default": "./dist/plugin/module/module.format.js"
    },
    "#tempo/mutate": {
      "development": "./src/plugin/module/module.mutate.ts",
      "default": "./dist/plugin/module/module.mutate.js"
    },
    "#tempo/ticker": {
      "development": "./src/plugin/extend/extend.ticker.ts",
      "default": "./dist/plugin/extend/extend.ticker.js"
    },
    "#tempo/term/standard": {
      "development": "./src/plugin/term/standard.index.ts",
      "default": "./dist/plugin/term/standard.index.js"
    },
    "#tempo/term": {
      "development": "./src/plugin/term/term.index.ts",
      "default": "./dist/plugin/term/term.index.js"
    },
    "#tempo/term/*": {
      "development": "./src/plugin/term/term.*.ts",
      "default": "./dist/plugin/term/term.*.js"
    },
    "#tempo/plugin/plugin.*.js": {
      "development": "./src/plugin/plugin.*.ts",
      "default": "./dist/plugin/plugin.*.js"
    },
    "#tempo/plugin/extend.*.js": {
      "development": "./src/plugin/extend/extend.*.ts",
      "default": "./dist/plugin/extend/extend.*.js"
    },
    "#tempo/plugin/module.*.js": {
      "development": "./src/plugin/module/module.*.ts",
      "default": "./dist/plugin/module/module.*.js"
    },
    "#tempo/plugin/term.*.js": {
      "development": "./src/plugin/term/term.*.ts",
      "default": "./dist/plugin/term/term.*.js"
    },
    "#tempo/*.js": {
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/tempo.index.d.ts",
      "import": "./dist/tempo.index.js"
    },
    "./enums": {
      "types": "./dist/tempo.enum.d.ts",
      "import": "./dist/tempo.enum.js"
    },
    "./extend/*": {
      "types": "./dist/plugin/extend/extend.*.d.ts",
      "import": "./dist/plugin/extend/extend.*.js"
    },
    "./module/*": {
      "types": "./dist/plugin/module/module.*.d.ts",
      "import": "./dist/plugin/module/module.*.js"
    },
    "./term/standard": {
      "types": "./dist/plugin/term/standard.index.d.ts",
      "import": "./dist/plugin/term/standard.index.js"
    },
    "./term/*": {
      "types": "./dist/plugin/term/term.*.d.ts",
      "import": "./dist/plugin/term/term.*.js"
    },
    "./plugin": {
      "types": "./dist/plugin/plugin.index.d.ts",
      "import": "./dist/plugin/plugin.index.js"
    },
    "./plugin/*": {
      "types": "./dist/plugin/*.d.ts",
      "import": "./dist/plugin/*.js"
    },
    "./ticker": {
      "types": "./dist/plugin/extend/extend.ticker.d.ts",
      "import": "./dist/plugin/extend/extend.ticker.js"
    },
    "./duration": {
      "types": "./dist/plugin/module/module.duration.d.ts",
      "import": "./dist/plugin/module/module.duration.js"
    },
    "./format": {
      "types": "./dist/plugin/module/module.format.d.ts",
      "import": "./dist/plugin/module/module.format.js"
    },
    "./mutate": {
      "types": "./dist/plugin/module/module.mutate.d.ts",
      "import": "./dist/plugin/module/module.mutate.js"
    },
    "./library": {
      "types": "./dist/library.index.d.ts",
      "import": "./dist/library.index.js"
    },
    "./core": {
      "types": "./dist/core.index.d.ts",
      "import": "./dist/core.index.js"
    },
    "./term": {
      "types": "./dist/plugin/term/term.index.d.ts",
      "import": "./dist/plugin/term/term.index.js"
    }
  },
  "scripts": {
    "test": "vitest run --workspace ../../vitest.workspace.ts",
    "repl": "tsx --conditions=development -i --import ./bin/setup.polyfill.ts --import ./bin/repl.ts",
    "core": "tsx --conditions=development -i --import ./bin/setup.polyfill.ts --import ./bin/core.ts",
    "build": "tsc -b && npm run build:bundle && npm run build:resolve",
    "build:bundle": "rollup -c",
    "build:resolve": "tsx bin/resolve-types.ts",
    "clean": "tsc -b --clean && rm -rf dist",
    "publish": "npm publish --access public",
    "prepublishOnly": "npm run build",
    "docs:api": "typedoc",
    "docs:dev": "npm run docs:api && vitepress dev",
    "docs:build": "npm run docs:api && vitepress build",
    "docs:preview": "vitepress preview"
  },
  "files": [
    "doc/",
    "dist/",
    ".vitepress/dist/"
  ],
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@magmacomputing/library": "workspace:*",
    "@rollup/plugin-alias": "^6.0.0",
    "magic-string": "^0.30.21",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitepress": "^1.6.4"
  },
  "directories": {
    "doc": "doc",
    "test": "test"
  }
}
